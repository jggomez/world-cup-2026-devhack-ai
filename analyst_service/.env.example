# Google Gemini API Key Authentication
GOOGLE_GENAI_USE_VERTEXAI=False
GEMINI_API_KEY=your-gemini-api-key-from-ai-studio

# Port configuration for FastAPI server
PORT=8000

# ADK Memory Bank Configuration (Vertex AI Agent Engine)
# Set AGENT_ENGINE_ID to enable VertexAiMemoryBankService; otherwise, falls back to InMemoryMemoryService
AGENT_ENGINE_ID=
GOOGLE_CLOUD_PROJECT=world-cup-2026-devhack
GOOGLE_CLOUD_LOCATION=us-central1
